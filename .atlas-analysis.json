  "keyFeatures": [
    "Shared WhatsApp Business inbox with multi-agent assignment",
    "Contact management with tags, custom fields, and CSV import",
    "Sales pipelines (Kanban) linked to conversations",
    "Template broadcasts with delivery and read tracking",
    "No-code visual automation builder (triggers, conditions, waits, webhooks)",
    "Programmable WhatsApp Flows with button/list interactive nodes",
    "AI reply assistant (OpenAI/Anthropic BYOK) with knowledge base and auto-reply bot",
    "Team accounts with role-based access (owner/admin/agent/viewer)",
    "Public REST API (/api/v1) with scoped, revocable API keys",
    "Outbound event webhooks with HMAC-SHA256 signature verification",
    "Real-time dashboard with response times, volume, and pipeline value",
    "AES-256-GCM token encryption, RLS on every table, HMAC-verified webhooks"
  ],
  "publicApiSurface": [
    "GET /api/v1/me",
    "POST /api/v1/messages",
    "GET /api/v1/contacts",
